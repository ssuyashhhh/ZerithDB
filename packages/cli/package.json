{
  "name": "zerithdb-cli",
  "version": "0.1.0",
  "description": "ZerithDB CLI — npx zerithdb init",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "zerithdb": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm",
    "dev": "tsup src/cli.ts --format esm --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "zerithdb-core": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.3.1",
    "ora": "^8.1.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "zerithdb-eslint-config": "workspace:*",
    "zerithdb-tsconfig": "workspace:*",
    "@types/prompts": "^2.4.9",
    "rimraf": "^6.0.1",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "templates"
  ]
}
