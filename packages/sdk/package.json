{
  "name": "zerithdb-sdk",
  "version": "0.1.0",
  "description": "ZerithDB SDK — build full-stack apps with zero backend",
  "keywords": [
    "local-first",
    "p2p",
    "webrtc",
    "crdt",
    "offline",
    "sync",
    "database"
  ],
  "homepage": "https://zerithdb.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zerith-Labs/ZerithDB.git",
    "directory": "packages/sdk"
  },
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --treeshake",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --root ../.. packages/sdk/src",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "zerithdb-auth": "workspace:*",
    "zerithdb-core": "workspace:*",
    "zerithdb-db": "workspace:*",
    "zerithdb-devtools": "workspace:*",
    "zerithdb-network": "workspace:*",
    "zerithdb-sync": "workspace:*",
    "zerithdb-errors": "workspace:*"
  },
  "devDependencies": {
    "zerithdb-eslint-config": "workspace:*",
    "zerithdb-tsconfig": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "fake-indexeddb": "^6.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "peerDependencies": {
    "zod": "^3.x"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src"
  ]
}
